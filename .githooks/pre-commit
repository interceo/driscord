#!/usr/bin/env bash
# Pre-commit hook: auto-format staged C/C++ files with clang-format.
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"

# Collect staged C/C++ files (src, tests, benchmarks, server)
STAGED=$(git diff --cached --name-only --diff-filter=ACM \
    | grep -E '\.(cpp|hpp|h|mm)$' \
    | grep -E '^(core/|backend/signaling_server/)' || true)

if [[ -z "$STAGED" ]]; then
    exit 0
fi

# Format and re-stage
for f in $STAGED; do
    clang-format -i "$ROOT/$f"
    git add "$ROOT/$f"
done
